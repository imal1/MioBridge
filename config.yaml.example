# ===============================================
# MioBridge 配置文件模板
# ===============================================
# 运行时由 miobridge CLI 读取。首次引导后，setup、update、dashboard 生命周期、
# upgrade 和 uninstall 都通过 miobridge 命令完成，不依赖服务器端管理脚本。
# ===============================================

# 服务基础配置
# ---------------------------------------------
app:
  name: miobridge               # 应用名称
  version: 1.0.0                  # 应用版本
  port: 3000                      # 仪表盘与 API 端口
  environment: production         # 运行环境: development/production

# 本机节点是否参与聚合由 CLI 管理并保存在 nodes.yaml：
# miobridge nodes configure --local-node
# miobridge nodes configure --no-local-node

# 协议配置管理
# ---------------------------------------------
protocols:
  # sing-box 支持的配置类型
  sing_box_configs:
    - vless
    - hysteria2
    - trojan
    - tuic
    - vmess

# 二进制文件路径配置
# ---------------------------------------------
binaries:
  # mihomo (clash-meta 内核) 二进制文件路径
  # 留空则使用默认路径: $BASE_DIR/bin/mihomo
  mihomo_path: ""
  
# 目录结构配置
# ---------------------------------------------
directories:
  # 静态文件目录 (网站数据目录)
  # 默认: $BASE_DIR/www
  # 存储订阅文件、配置文件等静态资源
  data_dir: ""
  
  # 日志文件目录
  # 默认: $BASE_DIR/log
  # 存储应用日志和访问日志
  log_dir: ""
  
  # 备份文件目录
  # 默认: $BASE_DIR/backup
  backup_dir: ""
# 网络配置
# ---------------------------------------------
network:
  request_timeout: 30000        # 请求超时时间 (毫秒)
