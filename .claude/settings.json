{
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bun run:*)",
      "Bash(bun install:*)",
      "Bash(gh:*)",
      "Bash(gh workflow:*)",
      "Bash(gh run:*)",
      "Bash(systemctl:status miobridge)",
      "Bash(systemctl:restart miobridge)",
      "Bash(journalctl:-u miobridge*)",
      "Bash(journalctl:-u subscription*)",
      "Bash(curl:localhost:*)",
      "Bash(curl:http://localhost:*)",
      "Bash(curl:/api/health*)",
      "Bash(curl:/api/status*)",
      "Bash(git:*)",
      "Bash(oxlint:*)",
      "Bash(npx:tsc*)",
      "Bash(readlink:*)",
      "Bash(ls:~/.config/miobridge*)",
      "Bash(cat:~/.config/miobridge*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(tar:*)",
      "Bash(wc:*)",
      "Bash(ssh-keyscan:*)",
      "Bash(python3:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \"/home/imali/MioBridge\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph status --repo \"/home/imali/MioBridge\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
