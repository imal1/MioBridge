{
  "name": "miobridge",
  "version": "1.2.12",
  "description": "MioBridge — sing-box to Clash subscription converter powered by mihomo, supporting vless/vmess/trojan/hysteria2/tuic",
  "private": true,
  "packageManager": "bun@1.2.13",
  "workspaces": [
    "packages/*",
    "agent"
  ],
  "scripts": {
    "dev": "cd packages/frontend && bun run dev",
    "build": "cd packages/frontend && bun run build",
    "typecheck": "cd packages/frontend && bunx tsc --noEmit",
    "core:build": "bun run --cwd packages/core build",
    "core:test": "bun run --cwd packages/core test",
    "core:typecheck": "bun run --cwd packages/core typecheck",
    "cli:build": "bun run --cwd packages/cli build",
    "cli:release": "bun run --cwd packages/cli build:release",
    "cli:test": "bun run --cwd packages/cli test",
    "cli:typecheck": "bun run --cwd packages/cli typecheck",
    "e2e:setup": "bun install --frozen-lockfile && bun run --cwd packages/e2e browser:install:deps && bun run e2e:prepare && bun run --cwd packages/e2e typecheck",
    "e2e:prepare": "bun run cli:build && bun run build",
    "e2e:typecheck": "bun run cli:build && bun run --cwd packages/e2e typecheck",
    "e2e:smoke": "bun run e2e:prepare && bun run --cwd packages/e2e test -- tests/dashboard/shell-overview.spec.ts --project=desktop-chromium --grep=\"健康端点与 SPA fallback\"",
    "e2e:sop": "bun run e2e:prepare && bun run --cwd packages/e2e test:sop",
    "e2e": "bun run e2e:prepare && bun run --cwd packages/e2e test",
    "e2e:report": "bun run --cwd packages/e2e report",
    "start": "echo \"Use CLI: miobridge dashboard start\"",
    "lint": "oxlint packages/frontend/src/",
    "lint:fix": "oxlint --fix packages/frontend/src/",
    "clean": "rm -rf packages/frontend/dist",
    "frontend:dev": "cd packages/frontend && bun run dev",
    "frontend:build": "cd packages/frontend && bun run build",
    "frontend:lint": "cd packages/frontend && bun run lint"
  },
  "keywords": [
    "miobridge",
    "subscription-converter",
    "clash",
    "sing-box",
    "mihomo",
    "clash-meta",
    "vless",
    "vmess",
    "trojan",
    "hysteria2",
    "tuic",
    "typescript",
    "api",
    "proxy",
    "vpn",
    "protocol-conversion"
  ],
  "author": "imal1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imal1/miobridge.git"
  },
  "bugs": {
    "url": "https://github.com/imal1/miobridge/issues"
  },
  "homepage": "https://github.com/imal1/miobridge#readme",
  "devDependencies": {
    "oxlint": "^1.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
