{"nodes": [{"id": "_codex_memory_config_patterns_doc", "label": "Config Patterns Memory", "file_type": "document", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_codex_memory_config_patterns_createruntimepaths", "label": "createRuntimePaths", "file_type": "concept", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core runtime paths are resolved per instance through createRuntimePaths; frontend adapters must pass platform policies such as Vercel /tmp explicitly."}, {"id": "_codex_memory_config_patterns_miobridge_config_dir", "label": "MIOBRIDGE_CONFIG_DIR Override", "file_type": "concept", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MIOBRIDGE_CONFIG_DIR can override the runtime base dir for isolated tests; on Vercel without it, runtime scratch/log paths fall back to /tmp/miobridge to avoid read-only home directory failures."}, {"id": "_codex_memory_config_patterns_runtime_config_yaml", "label": "Runtime config.yaml", "file_type": "concept", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_codex_memory_config_patterns_ssh_keys_statestore", "label": "SSH Private Key StateStore Pattern", "file_type": "concept", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uploaded SSH private keys use StateStore keys ssh-keys/<nodeId>; nodes.yaml stores only authMethod and credentialRef. Password and private-key SSH authentication are mutually exclusive."}, {"id": "_codex_memory_config_patterns_kernels_list", "label": "Agent kernels List", "file_type": "concept", "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agent configs use a non-empty, duplicate-free kernels list of sing-box, Xray, and/or V2Ray entries, each with an optional config path; a node may use kernels: [] draft form until its first successful deploy."}], "edges": [{"source": "_codex_memory_config_patterns_doc", "target": "_codex_memory_config_patterns_createruntimepaths", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_config_patterns_doc", "target": "_codex_memory_config_patterns_miobridge_config_dir", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_config_patterns_doc", "target": "_codex_memory_config_patterns_runtime_config_yaml", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_config_patterns_doc", "target": "_codex_memory_config_patterns_ssh_keys_statestore", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_config_patterns_doc", "target": "_codex_memory_config_patterns_kernels_list", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/config-patterns.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_config_patterns_ssh_keys_statestore", "target": "_codex_memory_project_architecture_statestore_abstraction", "relation":