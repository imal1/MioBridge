{"nodes": [{"id": "_codex_memory_bug_fixes_doc", "label": "Bug Fixes Memory", "file_type": "document", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_codex_memory_bug_fixes_nodemanager_init_order", "label": "NodeManager Config Init Before Logger", "file_type": "rationale", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "NodeManager now initializes MioBridge/config before importing the shared logger; this avoids Bun leaving config in a TDZ while preserving the configured logging level and directory."}, {"id": "_codex_memory_bug_fixes_filestatestore_normalize", "label": "FileStateStore Base Dir Normalization", "file_type": "rationale", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FileStateStore normalizes its configured base directory before path-containment checks, so trailing separators no longer reject valid keys."}, {"id": "_codex_memory_bug_fixes_atomic_rename_deploy", "label": "Atomic Rename for Agent systemd Deploy", "file_type": "rationale", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agent config and systemd unit deployment uses checked, same-directory temporary files plus atomic rename; sudo passwords travel over SSH stdin, node YAML strings use JSON-compatible quoting, and proxy logs omit credentials and complete URLs."}, {"id": "_codex_memory_bug_fixes_build_agent_on_remote", "label": "buildAgentOnRemote", "file_type": "concept", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agent deploy no longer requires the ~100MB compiled binary in the control plane bundle; when agent/miobridge-agent is missing locally (Vercel), the target host downloads the repo tarball pinned to the control plane commit and compiles the agent with its own Bun. Self-hosted control planes with the binary still SFTP-upload."}, {"id": "_codex_memory_bug_fixes_hmac_endpoints", "label": "Public HMAC Agent Endpoints", "file_type": "concept", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Normal Agent status/health/URL checks use public HMAC endpoints only; SSH fallback is reserved for deployment and diagnostics so routine monitoring does not require SSH access."}, {"id": "_codex_memory_bug_fixes_statestore_registry_persistence", "label": "StateStore Registry and Progress Persistence", "file_type": "rationale", "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Node registry and deploy progress no longer vanish between Vercel function instances because nodes.yaml IO and deployProgressStore go through the StateStore abstraction (file backend by default, Redis REST when configured); without Redis env vars on Vercel the old ephemeral behavior remains with a startup warning."}], "edges": [{"source": "_codex_memory_bug_fixes_doc", "target": "_codex_memory_bug_fixes_nodemanager_init_order", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_bug_fixes_doc", "target": "_codex_memory_bug_fixes_filestatestore_normalize", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".Codex/memory/bug-fixes.md", "source_location": null, "weight": 1.0}, {"source": "_codex_memory_bug_fixes_doc", "target": "_code