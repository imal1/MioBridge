{"nodes": [{"id": "doc_design_images_logs_logspage", "label": "MioBridge Logs/Diagnostics Page", "file_type": "image", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Failure-source diagnostics workflow: first locate the problem by failure source, then confirm details with raw logs. The page surfaces categorized failure sources on the left and live evidence logs on the right so operators can move from category to concrete log line in one view."}, {"id": "doc_design_images_logs_sidebar_navigation", "label": "Sidebar Navigation (MioBridge Dashboard)", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "doc_design_images_logs_failure_sources_panel", "label": "Failure Sources Panel", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each failure source is rendered as a row with a status pill: \u6b63\u5e38 (Normal), \u8b66\u544a (Warning), \u8d85\u65f6 (Timeout), \u901a\u8fc7 (Passed). This categorizes the diagnostic state per subsystem so the operator can see at a glance which stage is unhealthy."}, {"id": "doc_design_images_logs_evidence_log_panel", "label": "Evidence Log Panel", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Right pane shows a live-stream (\u5b9e\u65f6\u6d41) raw log from production.log, paired with a structured triage header: \u5b9a\u4f4d (Location) -> \u8282\u70b9 (Node) -> \u5f71\u54cd (Impact). This binds the abstract failure category to a concrete node and to a downstream artifact (clash.yaml)."}, {"id": "doc_design_images_logs_recommended_actions_button", "label": "View Recommended Actions Button", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The failure-sources pane ends with a single primary CTA. Design intent: collapse the categorized failures into a single next action so the operator does not have to read every row to know what to do."}, {"id": "doc_design_images_logs_live_tail_indicator", "label": "Live Tail Indicator", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A persistent 'live tail' badge in the sidebar signals the page is streaming. The status header on the right shows '\u8ba2\u9605\u6e90\u8d85\u65f6\u5df2\u5f52\u7c7b' (subscription timeout categorized) - the page does real-time classification, not just log display."}, {"id": "doc_design_images_logs_failure_source_local_kernel", "label": "Failure Source: Local Kernel", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "doc_design_images_logs_failure_source_remote_agent", "label": "Failure Source: Remote Agent", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "doc_design_images_logs_failure_source_subscription_source", "label": "Failure Source: Subscription Source", "file_type": "concept", "source_file": "doc/design/images/logs.jpg", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "doc_design_images_logs_failure_source_mihomo_conversion", "label": "Failure Source: Mihomo Conversion", "file_type": "concept", "source_file": "doc/design/images/l