{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@adapters/*": ["../packages/frontend/src/server/services/adapters/*"],
      "@middleware/*": ["../packages/frontend/src/server/middleware/*"],
      "@types/*": ["../packages/frontend/src/server/types/*"]
    }
  },
  "include": ["src/**/*.ts", "../packages/frontend/src/server/services/adapters/**/*.ts", "../packages/frontend/src/server/middleware/**/*.ts", "../packages/frontend/src/server/types/**/*.ts"],
  "exclude": ["node_modules", "src/**/__tests__/**"]
}
