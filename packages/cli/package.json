{
  "name": "@miobridge/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "miobridge": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run --cwd ../core build && tsc -p tsconfig.json",
    "build:release": "bash ../../scripts/package-cli-release.sh",
    "test": "bun run build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@miobridge/core": "workspace:*",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "@types/ssh2": "^1.15.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
